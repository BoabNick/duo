# DUOPAY Server Configuration

# Port the server listens on
PORT=3000

# Database path (SQLite)
DB_PATH=./duopay.db

# Node environment
NODE_ENV=production

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Optional: Stripe API key (for future payment processing)
# STRIPE_API_KEY=sk_live_...

# Optional: Twilio API key (for future SMS notifications)
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
