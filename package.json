{
  "name": "duopay-app",
  "version": "1.0.0",
  "description": "DUOPAY - POS app with SPIn & PAX terminal integrations (web + Android/iOS via Capacitor)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:open:android": "cap open android",
    "android:build": "cap sync android && cd android && ./gradlew assembleDebug",
    "android:build:release": "cap sync android && cd android && ./gradlew assembleRelease"
  },
  "keywords": [
    "pos",
    "payment",
    "spin",
    "pax",
    "terminal",
    "capacitor",
    "android"
  ],
  "author": "DUOPAY",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
